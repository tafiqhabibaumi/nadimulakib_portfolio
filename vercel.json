{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "_next/**",
          "images/**",
          "icons/**",
          "projects/**",
          "logo/**",
          "index.html",
          "admin.html",
          "index.template.html"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
